datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  BUYER
  SELLER
  BOTH
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum KycType {
  INDIVIDUAL
  COMPANY
}

enum InvestorType {
  INDIVIDUAL
  PE_FUND
  FAMILY_OFFICE
  CORPORATE
}

enum ExperienceLevel {
  FIRST_TIME
  SOME
  EXPERIENCED
  SERIAL
}

enum AssetType {
  SAAS
  ECOMMERCE
  APP
  BLOG
  DOMAIN
  CONTENT_SITE
  SERVICE
}

enum PricingModel {
  AUCTION
  CLASSIFIED
}

enum ListingStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  LIVE
  PAUSED
  SOLD
  REJECTED
}

enum DocumentType {
  FINANCIAL
  ANALYTICS
  OWNERSHIP
  PITCH_DECK
  OTHER
}

enum NdaStatus {
  PENDING
  SIGNED
  EXPIRED
}

enum OfferStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum DealStage {
  NDA
  DUE_DILIGENCE
  AGREEMENT
  ESCROW
  TRANSFER
  CLOSED
  CANCELLED
}

enum EscrowStatus {
  NOT_CREATED
  PENDING
  FUNDED
  RELEASED
  REFUNDED
}

enum DealDocumentType {
  PROOF_OF_FUNDS
  AGREEMENT
  TRANSFER_PROOF
  NDA
  OTHER
}

enum Visibility {
  BOTH
  BUYER_ONLY
  SELLER_ONLY
  ADMIN_ONLY
}

enum ChecklistItemAssignee {
  BUYER
  SELLER
  PLATFORM
}

enum MessageType {
  TEXT
  SYSTEM
  DOCUMENT
}

enum PaymentPurpose {
  NDA_FEE
  LISTING_FEE
  ESCROW
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum ReviewRole {
  BUYER
  SELLER
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  phone         String?   @unique
  phoneVerified Boolean   @default(false) @map("phone_verified")
  name          String
  avatarUrl     String?   @map("avatar_url")
  role          Role      @default(BUYER)
  kycStatus     KycStatus @default(NOT_STARTED) @map("kyc_status")
  kycType       KycType?  @map("kyc_type")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relationships
  kycProfiles         KycProfile[]          @relation("UserKycProfiles")
  reviewedKycProfiles KycProfile[]          @relation("KycReviewer")
  buyerProfiles       BuyerProfile[]
  listings            Listing[]
  ndaAgreements       NdaAgreement[]
  offersSent          Offer[]               @relation("BuyerOffers")
  offersReceived      Offer[]               @relation("SellerOffers")
  dealsAsBuyer        Deal[]                @relation("BuyerDeals")
  dealsAsSeller       Deal[]                @relation("SellerDeals")
  dealDocuments       DealDocument[]
  completedChecklist  DealChecklistItem[]
  messagesSent        Message[]
  notifications       Notification[]
  payments            Payment[]
  reviewsWritten      Review[]              @relation("Reviewer")
  reviewsReceived     Review[]              @relation("Reviewee")
  sessions            Session[]
  accounts            Account[]

  @@index([role])
  @@index([kycStatus])
  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id") @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("accounts")
}

model Verification {
  id         String    @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verifications")
}

model KycProfile {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  panNumber         String?   @map("pan_number")
  aadhaarLast4      String?   @map("aadhaar_last4")
  panDocUrl         String?   @map("pan_doc_url")
  aadhaarDocUrl     String?   @map("aadhaar_doc_url")
  selfieUrl         String?   @map("selfie_url")
  bankAccountName   String?   @map("bank_account_name")
  bankAccountNumber String?   @map("bank_account_number")
  bankIfsc          String?   @map("bank_ifsc")
  companyName       String?   @map("company_name")
  cin               String?   @map("cin")
  gstin             String?   @map("gstin")
  companyPan        String?   @map("company_pan")
  directorName      String?   @map("director_name")
  status            KycStatus @default(PENDING)
  rejectionReason   String?   @map("rejection_reason")
  reviewedBy        String?   @map("reviewed_by") @db.Uuid
  reviewedAt        DateTime? @map("reviewed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  user     User  @relation("UserKycProfiles", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("KycReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@map("kyc_profiles")
}

model BuyerProfile {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @map("user_id") @db.Uuid
  investorType         InvestorType?    @map("investor_type")
  industries           String[]
  states               String[]
  budgetMin            Int?             @map("budget_min")
  budgetMax            Int?             @map("budget_max")
  acquisitionGoal      String?          @map("acquisition_goal")
  experienceLevel      ExperienceLevel? @map("experience_level")
  proofOfFundsVerified Boolean          @default(false) @map("proof_of_funds_verified")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  deletedAt            DateTime?        @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deletedAt])
  @@map("buyer_profiles")
}

model Listing {
  id                  String        @id @default(uuid()) @db.Uuid
  sellerId            String        @map("seller_id") @db.Uuid
  slug                String        @unique
  title               String
  businessNamePrivate String?       @map("business_name_private")
  assetType           AssetType     @map("asset_type")
  industry            String
  businessModel       String?       @map("business_model")
  yearEstablished     Int?          @map("year_established")
  businessUrl         String?       @map("business_url")
  monthlyRevenue      Int?          @map("monthly_revenue")
  monthlyProfit       Int?          @map("monthly_profit")
  monthlyTraffic      Int?          @map("monthly_traffic")
  trafficSources      String?       @map("traffic_sources")
  askingPrice         Int           @map("asking_price")
  reasonForSale       String?       @map("reason_for_sale")
  description         String?       @db.Text
  tagline             String?
  teamSize            Int?          @map("team_size")
  hoursPerWeek        Int?          @map("hours_per_week")
  pricingModel        PricingModel  @default(CLASSIFIED) @map("pricing_model")
  reservePrice        Int?          @map("reserve_price")
  status              ListingStatus @default(DRAFT)
  ndaRequired         Boolean       @default(true) @map("nda_required")
  ndaFee              Int           @default(0) @map("nda_fee")
  isFeatured          Boolean       @default(false) @map("is_featured")
  coverImageUrl       String?       @map("cover_image_url")
  tags                String[]
  viewCount           Int           @default(0) @map("view_count")
  publishedAt         DateTime?     @map("published_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  deletedAt           DateTime?     @map("deleted_at")

  seller    User              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  documents ListingDocument[]
  ndas      NdaAgreement[]
  offers    Offer[]
  deals     Deal[]
  payments  Payment[]

  @@index([sellerId])
  @@index([status])
  @@index([assetType])
  @@index([askingPrice])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("listings")
}

model ListingDocument {
  id           String       @id @default(uuid()) @db.Uuid
  listingId    String       @map("listing_id") @db.Uuid
  type         DocumentType
  name         String
  url          String
  cloudinaryId String?      @map("cloudinary_id")
  isPrivate    Boolean      @default(true) @map("is_private")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([deletedAt])
  @@map("listing_documents")
}

model NdaAgreement {
  id        String    @id @default(uuid()) @db.Uuid
  listingId String    @map("listing_id") @db.Uuid
  buyerId   String    @map("buyer_id") @db.Uuid
  status    NdaStatus @default(PENDING)
  signedAt  DateTime? @map("signed_at")
  paymentId String?   @map("payment_id") @db.Uuid
  feePaid   Decimal?  @map("fee_paid") @db.Decimal(10, 2)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([listingId, buyerId])
  @@index([listingId])
  @@index([buyerId])
  @@index([status])
  @@index([deletedAt])
  @@map("nda_agreements")
}

model Offer {
  id             String      @id @default(uuid()) @db.Uuid
  listingId      String      @map("listing_id") @db.Uuid
  buyerId        String      @map("buyer_id") @db.Uuid
  sellerId       String      @map("seller_id") @db.Uuid
  amount         Decimal     @db.Decimal(12, 2)
  upfrontPercent Decimal     @default(100) @map("upfront_percent") @db.Decimal(5, 2)
  earnoutPercent Decimal     @default(0) @map("earnout_percent") @db.Decimal(5, 2)
  earnoutTerms   String?     @map("earnout_terms") @db.Text
  message        String?     @db.Text
  status         OfferStatus @default(PENDING)
  counterAmount  Decimal?    @map("counter_amount") @db.Decimal(12, 2)
  counterMessage String?     @map("counter_message") @db.Text
  expiresAt      DateTime?   @map("expires_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)
  seller  User    @relation("SellerOffers", fields: [sellerId], references: [id], onDelete: Cascade)
  deals   Deal[]

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("offers")
}

model Deal {
  id              String       @id @default(uuid()) @db.Uuid
  listingId       String       @map("listing_id") @db.Uuid
  offerId         String       @map("offer_id") @db.Uuid
  buyerId         String       @map("buyer_id") @db.Uuid
  sellerId        String       @map("seller_id") @db.Uuid
  stage           DealStage    @default(DUE_DILIGENCE)
  dealValue       Decimal      @map("deal_value") @db.Decimal(12, 2)
  escrowStatus    EscrowStatus @default(NOT_CREATED) @map("escrow_status")
  escrowReference String?      @map("escrow_reference")
  buyerSigned     Boolean      @default(false) @map("buyer_signed")
  sellerSigned    Boolean      @default(false) @map("seller_signed")
  signedAt        DateTime?    @map("signed_at")
  closedAt        DateTime?    @map("closed_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  listing        Listing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  offer          Offer               @relation(fields: [offerId], references: [id], onDelete: Cascade)
  buyer          User                @relation("BuyerDeals", fields: [buyerId], references: [id], onDelete: Cascade)
  seller         User                @relation("SellerDeals", fields: [sellerId], references: [id], onDelete: Cascade)
  documents      DealDocument[]
  checklistItems DealChecklistItem[]
  messages       Message[]
  reviews        Review[]
  payments       Payment[]

  @@index([listingId])
  @@index([offerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([stage])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("deals")
}

model DealDocument {
  id           String           @id @default(uuid()) @db.Uuid
  dealId       String           @map("deal_id") @db.Uuid
  uploadedBy   String           @map("uploaded_by") @db.Uuid
  type         DealDocumentType
  name         String
  url          String
  cloudinaryId String?          @map("cloudinary_id")
  visibility   Visibility       @default(BOTH)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")

  deal     Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([uploadedBy])
  @@index([deletedAt])
  @@map("deal_documents")
}

model DealChecklistItem {
  id          String                @id @default(uuid()) @db.Uuid
  dealId      String                @map("deal_id") @db.Uuid
  title       String
  description String?
  assignedTo  ChecklistItemAssignee @map("assigned_to")
  isCompleted Boolean               @default(false) @map("is_completed")
  completedBy String?               @map("completed_by") @db.Uuid
  completedAt DateTime?             @map("completed_at")
  sortOrder   Int                   @default(0) @map("sort_order")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  deletedAt   DateTime?             @map("deleted_at")

  deal      Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  completer User? @relation(fields: [completedBy], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([sortOrder])
  @@index([deletedAt])
  @@map("deal_checklist_items")
}

model Message {
  id          String      @id @default(uuid()) @db.Uuid
  dealId      String      @map("deal_id") @db.Uuid
  senderId    String      @map("sender_id") @db.Uuid
  content     String      @db.Text
  type        MessageType @default(TEXT)
  documentUrl String?     @map("document_url")
  isRead      Boolean     @default(false) @map("is_read")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  deal   Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([senderId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("messages")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String
  title     String
  body      String?
  data      Json?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

model Payment {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @map("user_id") @db.Uuid
  listingId         String?        @map("listing_id") @db.Uuid
  dealId            String?        @map("deal_id") @db.Uuid
  purpose           PaymentPurpose
  amount            Decimal        @db.Decimal(12, 2)
  currency          String         @default("INR")
  provider          String         @default("razorpay")
  providerOrderId   String?        @map("provider_order_id")
  providerPaymentId String?        @map("provider_payment_id")
  status            PaymentStatus  @default(CREATED)
  paidAt            DateTime?      @map("paid_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  ndaAgreements NdaAgreement[]

  @@index([userId])
  @@index([listingId])
  @@index([dealId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("payments")
}

model Review {
  id         String     @id @default(uuid()) @db.Uuid
  dealId     String     @map("deal_id") @db.Uuid
  reviewerId String     @map("reviewer_id") @db.Uuid
  revieweeId String     @map("reviewee_id") @db.Uuid
  role       ReviewRole
  rating     Int
  comment    String?    @db.Text
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")

  deal     Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  reviewer User @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([deletedAt])
  @@map("reviews")
}
